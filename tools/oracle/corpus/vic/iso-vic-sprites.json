{
  "name": "iso-vic-sprites",
  "slice": "vic",
  "trace": true,
  "steps": [
    { "method": "session/create", "params": { "pal": true }, "capture": true, "label": "create" },
    { "method": "monitor/exec", "params": { "session_id": "$sessionId", "command": "wr 0800 78 A9 FF 8D 15 D0 A9 64 8D 01 D0 A9 6E 8D 03 D0 A9 1B 8D 11 D0 4C 17 08" }, "capture": true, "label": "inject" },
    { "method": "monitor/exec", "params": { "session_id": "$sessionId", "command": "r pc=0800" }, "capture": true, "label": "setpc" },
    { "method": "trace/start_domains", "params": { "session_id": "$sessionId", "domains": ["vic"] }, "capture": true, "label": "trace-start" },
    { "method": "session/run", "params": { "session_id": "$sessionId", "cycles": 25000 }, "capture": true, "label": "run" },
    { "method": "trace/run/stop", "params": { "session_id": "$sessionId", "wait_index": true }, "label": "trace-stop" },
    { "method": "trace/run/status", "params": { "session_id": "$sessionId" }, "capture": true, "label": "trace-status" }
  ]
}
