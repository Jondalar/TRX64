{
  "name": "drive-boot-deep",
  "slice": "drive",
  "trace": true,
  "steps": [
    {
      "method": "session/create",
      "params": { "pal": true },
      "capture": true,
      "label": "create"
    },
    {
      "method": "trace/start_domains",
      "params": {
        "session_id": "$sessionId",
        "domains": ["drive8-cpu"]
      },
      "capture": true,
      "label": "trace-start"
    },
    {
      "method": "session/run",
      "params": { "session_id": "$sessionId", "cycles": 2000000 },
      "label": "run"
    },
    {
      "method": "trace/run/stop",
      "params": { "session_id": "$sessionId", "wait_index": true },
      "label": "trace-stop"
    },
    {
      "method": "trace/run/status",
      "params": { "session_id": "$sessionId" },
      "capture": true,
      "label": "trace-status"
    }
  ]
}
