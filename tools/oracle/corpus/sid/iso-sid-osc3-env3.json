{
  "name": "iso-sid-osc3-env3",
  "slice": "sid",
  "trace": true,
  "steps": [
    { "method": "session/create", "params": { "pal": true }, "capture": true, "label": "create" },
    {
      "method": "monitor/exec",
      "params": {
        "session_id": "$sessionId",
        "command": "wr 0800 78 A9 10 8D 0F D4 A9 00 8D 0E D4 A9 00 8D 13 D4 A9 F0 8D 14 D4 A9 21 8D 12 D4 AD 1B D4 8D 00 02 AD 1C D4 8D 01 02 4C 26 08"
      },
      "capture": true,
      "label": "inject"
    },
    { "method": "monitor/exec", "params": { "session_id": "$sessionId", "command": "r pc=0800" }, "capture": true, "label": "setpc" },
    {
      "method": "trace/start_domains",
      "params": { "session_id": "$sessionId", "domains": ["c64-cpu", "memory", "sid"] },
      "capture": true,
      "label": "trace-start"
    },
    { "method": "session/run", "params": { "session_id": "$sessionId", "cycles": 2000 }, "capture": true, "label": "run" },
    { "method": "trace/run/stop", "params": { "session_id": "$sessionId", "wait_index": true }, "label": "trace-stop" },
    { "method": "trace/run/status", "params": { "session_id": "$sessionId" }, "capture": true, "label": "trace-status" },
    {
      "method": "monitor/exec",
      "params": { "session_id": "$sessionId", "command": "m 0200 0201" },
      "capture": true,
      "label": "read-osc3-env3"
    }
  ]
}
